# ── Supabase ────────────────────────────────────────────────────────────────
# Copy this file to .env.local and fill in the values from your Supabase project
# (Project Settings → API). Never commit .env.local.

# Browser-safe: used by both client and server. Safe to expose.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only secret. NEVER prefix with NEXT_PUBLIC_, never ship to the browser.
# Used for admin/server actions that must bypass Row Level Security.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Notes ─────────────────────────────────────────────────────────────────────
# If the two NEXT_PUBLIC_ vars are absent, the app runs in OFFLINE DEMO mode:
# reads are served from in-memory seed data so you can preview the UI without a
# database. Writes (submitting/approving bookings) require a real Supabase project.
